# AAISM Environment Variables
# Copy to .env.local and fill in values. Never commit secrets.
#
# NOTE: End users can override these in-app via Settings → Integrations
# (stored in localStorage as aaism-integrations-config). Env vars apply
# when in-app config is empty — useful for maintainer builds only.

# ===== Donations (hosted checkout URLs) =====
# VITE_DONATE_STRIPE=https://buy.stripe.com/your-link
# VITE_DONATE_RAZORPAY=https://razorpay.me/@yourname
# VITE_DONATE_PAYPAL=https://paypal.me/yourname
# VITE_DONATE_KOFI=https://ko-fi.com/yourname
# VITE_DONATE_BMC=https://buymeacoffee.com/yourname
# VITE_DONATE_WISE=https://wise.com/pay/me/yourname
# VITE_DONATE_UPI=yourname@upi
# VITE_DONATE_BANK_INDIA=Account: XXXX · IFSC: XXXX · Name: AAISM Fund
# VITE_DONATE_SEPA=IBAN: DE00 XXXX · BIC: XXXX · Reference: AAISM-SUPPORT
# VITE_DONATE_BTC=bc1q...
# VITE_DONATE_ETH=0x...
# VITE_DONATE_USDC=0x...

# ===== Cloud sync (optional — Supabase) =====
# Prefer in-app Settings → Integrations for per-user config on GitHub Pages.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key (public key only — never service role)

# ===== Feature request checkout (optional) =====
# VITE_FEATURE_STRIPE=https://buy.stripe.com/your-feature-link
